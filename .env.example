APP_NAME=ProjectVault API
APP_ENV=local

POSTGRES_DB=projectvault
POSTGRES_USER=projectvault
POSTGRES_PASSWORD=projectvault
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://projectvault:projectvault@db:5432/projectvault

JWT_SECRET_KEY=change-this-local-secret-with-32-bytes-minimum
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

DOCUMENT_STORAGE_BACKEND=local
DOCUMENT_STORAGE_PATH=storage/documents

S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=projectvault-documents
S3_ACCESS_KEY=projectvault
S3_SECRET_KEY=projectvault-secret
S3_REGION=us-east-1
S3_PRESIGNED_URL_EXPIRES_SECONDS=900
